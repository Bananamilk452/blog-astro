<style>
	.social-icon-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 999px;
	}

	.social-icon-link svg {
		width: 1.2rem;
		height: 1.2rem;
	}
</style>
