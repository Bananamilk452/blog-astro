---
import SocialIcon from './SocialIcon.astro';

const today = new Date();
---

<footer class="footer-wrap">
	<div class="paper footer-note border">
		<div class="footer-links">
			<SocialIcon name="misskey" label="Misskey" href="https://serafuku.moe/@starterdroid" />
			<SocialIcon name="bluesky" label="Bluesky" href="https://bsky.app/profile/seoa.dev" />
			<SocialIcon name="twitter" label="Twitter" href="https://x.com/lemon_gr_/" />
			<SocialIcon name="github" label="GitHub" href="https://github.com/Bananamilk452/blog-astro" />
		</div>
		<p class="copyright">Copyright &copy; {today.getFullYear()} 윤서아. All rights reserved.</p>
		<p class="repo muted">깃허브: Bananamilk452/blog-astro</p>
	</div>
</footer>
<style>
	.footer-wrap {
		padding: 0 1rem 2rem;
	}

	.footer-note {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.4rem 1.5rem;
		border-radius: 24px;
		background: rgba(255, 253, 245, 0.92);
		text-align: center;
	}

	.footer-links {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin-bottom: 0.9rem;
	}

	.footer-links a {
		display: inline-flex;
		padding: 0;
		border-radius: 999px;
		background: rgba(255, 247, 204, 0.7);
		text-decoration: none;
		color: var(--ink);
	}

	.copyright,
	.repo {
		margin: 0;
	}

	.repo {
		margin-top: 0.35rem;
		font-size: 0.95rem;
	}

	@media (max-width: 900px) {
		.footer-wrap {
			padding-inline: 0.5rem;
		}

		.footer-note {
			width: calc(100% - 1rem);
		}
	}
</style>
