---
import SocialIcon from './SocialIcon.astro';
import { SITE_TITLE } from '../consts';
---

<header class="site-header-wrap">
	<nav class="paper site-header border split-nav">
		<div class="nav-brand brand-block justify-center">
			<h1><a href="/">{SITE_TITLE}</a></h1>
		</div>
		<div class="collapsible justify-center">
			<div class="collapsible-body nav-sections">
				<ul class="inline social-links">
					<li><SocialIcon name="twitter" label="Twitter" href="https://x.com/lemon_gr_/" /></li>
					<li><SocialIcon name="misskey" label="Misskey" href="https://serafuku.moe/@starterdroid" /></li>
					<li><SocialIcon name="bluesky" label="Bluesky" href="https://bsky.app/profile/seoa.dev" /></li>
				</ul>
			</div>
		</div>
	</nav>
</header>
<style>
	.site-header-wrap {
		padding: 1.2rem 1rem 0;
	}

	.site-header {
		width: min(1120px, calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.8rem 1.4rem;
		border-radius: 28px;
		background: rgba(255, 253, 245, 0.95);
		backdrop-filter: blur(6px);
		box-shadow: var(--shadow);
	}

	.brand-block {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 5vw, 3rem);
		line-height: 1;
	}

	h1 a,
	h1 a.active {
		color: var(--ink);
		text-decoration: none;
	}

	.nav-sections {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.social-links {
		margin: 0;
		padding: 0;
		gap: 0.6rem;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		color: var(--ink);
		background: rgba(255, 247, 204, 0.75);
		text-decoration: none;
		border-bottom: 0;
		font-size: 1rem;
		line-height: 1.2;
	}

	.social-links a {
		padding: 0;
	}

	@media (max-width: 900px) {
		.site-header {
			width: calc(100% - 1rem);
			padding: 0.9rem 1rem;
		}

		.nav-sections {
			align-items: flex-start;
			flex-direction: column;
			padding-top: 1rem;
		}

		.social-links {
			display: flex;
			flex-wrap: wrap;
		}
	}

	@media (max-width: 560px) {
		.site-header-wrap {
			padding-inline: 0.5rem;
		}

		h1 {
			font-size: 1.75rem;
		}
	}
</style>
