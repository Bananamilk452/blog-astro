---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="home-hero page-note">
				<h1>윤서아의 블로그</h1>
				<p class="hero-copy">
					종이 위에 메모를 쌓아두듯, 천천히 읽고 오래 남는 글들을 정리하는 공간입니다.
				</p>
				<ul class="tag-list">
					<li>기록</li>
					<li>개발</li>
					<li>메모</li>
				</ul>
			</section>

			<section class="post-section">
				<div class="section-heading">
					<h2>최근 글 목록</h2>
					<p class="muted">메모장에 꽂아둔 최신 글들</p>
				</div>
				<ul class="post-grid" aria-label="블로그 글 목록">
					{
						posts.map((post) => (
							<li class="paper-card post-card">
								<a class="card-link" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image class="card-image" width={720} height={420} src={post.data.heroImage} alt="" />
									)}
									<p class="post-date handwritten"><FormattedDate date={post.data.pubDate} /></p>
									<h3>{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-hero {
		display: grid;
		gap: 1rem;
		max-width: 880px;
		margin: 0 auto 2rem;
		padding: 2rem;
	}

	.hero-copy {
		max-width: 36rem;
		margin: 0;
		font-size: 1.05rem;
	}

	.post-section {
		margin-top: 2.5rem;
	}

	.section-heading {
		max-width: 880px;
		margin: 0 auto 1rem;
		padding: 0 0.5rem;
	}

	.section-heading p {
		margin-top: 0.45rem;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1.4rem;
		max-width: 1000px;
		margin: 0 auto;
		padding: 0;
		list-style: none;
	}

	.post-card {
		height: 100%;
	}

	.card-link {
		display: grid;
		gap: 0.9rem;
		height: 100%;
		color: inherit;
		background-image: none;
		text-decoration: none;
	}

	.card-link:hover,
	.card-link:visited {
		background-image: none;
		text-decoration: none;
	}

	.card-image {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 16px;
		box-shadow: var(--shadow-soft);
	}

	.post-date {
		margin: 0;
		font-size: 0.95rem;
		color: var(--ink-soft);
	}

	.post-description {
		color: var(--ink-soft);
	}

	@media (max-width: 900px) {
		.post-grid {
			grid-template-columns: 1fr;
		}

		.home-hero {
			padding: 1.4rem;
		}
	}
</style>
