---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Array<{
		depth: number;
		slug: string;
		text: string;
	}>;
};

const { title, description, pubDate, updatedDate, heroImage, headings = [] } = Astro.props;
---

<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="post-main">
			<div class="post-layout">
				{headings.length > 0 && (
					<aside class="paper toc-panel">
						<p class="toc-title">목차</p>
						<ul>
							{
								headings
									.filter((heading) => heading.depth <= 3)
									.map((heading) => (
										<li class={`depth-${heading.depth}`}>
											<a href={`#${heading.slug}`}>{heading.text}</a>
										</li>
									))
							}
						</ul>
					</aside>
				)}

				<article class="post-column">
					{heroImage && (
						<div class="hero-image">
							<Image width={1400} height={740} src={heroImage} alt="" />
						</div>
					)}

					<section class="paper-panel post-header">
						<h1>{title}</h1>
						<p class="post-description">{description}</p>
						<div class="author-row">
							<div class="author-card">
								<img src="/profile.png" alt="윤서아 프로필 사진" width="68" height="68" />
								<div>
									<p class="author-name">윤서아</p>
								</div>
							</div>
							<div class="date-card">
								<p class="muted">작성일</p>
								<p><FormattedDate date={pubDate} /></p>
								{
									updatedDate && (
										<p class="updated-note muted">수정일 <FormattedDate date={updatedDate} /></p>
									)
								}
							</div>
						</div>
					</section>

					<section class="paper-panel prose content-panel">
						<slot />
					</section>

					<!-- <section class="paper-panel comments-panel">
						<h3>댓글</h3>
						<p class="muted">댓글 기능은 추후 구현 예정입니다.</p>
					</section> -->
				</article>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.post-main {
		width: min(1360px, calc(100% - 2rem));
	}

	.post-layout {
		position: relative;
		min-height: 100vh;
	}

	.toc-panel {
		position: fixed;
		top: 8.6rem;
		left: 1.4rem;
		width: 190px;
		padding: 0.85rem;
		border-radius: 22px;
		background: rgba(255, 253, 245, 0.92);
		box-shadow: var(--shadow-soft);
	}

	.toc-title {
		margin: 0 0 0.8rem;
		font-size: 0.88rem;
		color: var(--ink-soft);
	}

	.toc-panel ul {
		margin: 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.4rem;
	}

	.toc-panel li {
		font-size: 0.85rem;
		line-height: 1.3;
	}

	.toc-panel li.depth-3 {
		padding-left: 0.7rem;
	}

	.toc-panel a {
		color: var(--ink-soft);
		text-decoration: none;
	}

	.toc-panel a:hover {
		color: var(--accent-strong);
		text-decoration: underline;
	}

	.post-column {
		width: min(860px, 100%);
		margin: 0 auto;
		display: grid;
		gap: 1.3rem;
	}

	.hero-image img {
		width: 100%;
		border-radius: 28px;
		box-shadow: var(--shadow);
		object-fit: cover;
	}

	.post-header,
	.content-panel,
	.comments-panel {
		background: rgba(255, 253, 245, 0.96);
	}

	.post-description {
		margin-top: 0.8rem;
		color: var(--ink-soft);
	}

	.author-row {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 1.5rem;
		padding-top: 1.2rem;
		border-top: 2px dashed var(--line);
	}

	.author-card,
	.date-card {
		display: flex;
		align-items: center;
		gap: 0.9rem;
	}

	.author-card img {
		border-radius: 50%;
		object-fit: cover;
		border: 4px solid rgba(255, 247, 204, 0.95);
	}

	.author-name,
	.date-card p,
	.updated-note {
		margin: 0;
	}

	.prose {
		font-size: 1rem;
	}

	.prose > :last-child {
		margin-bottom: 0;
	}

	.prose :global(h2),
	.prose :global(h3),
	.prose :global(h4) {
		margin-top: 2rem;
		margin-bottom: 0.9rem;
	}

	.prose :global(ul),
	.prose :global(ol) {
		padding-left: 1.4rem;
	}

	.comments-panel h3 {
		margin-bottom: 0.6rem;
	}

	@media (max-width: 1360px) {
		.toc-panel {
			display: none;
		}

		.post-main {
			width: min(100%, calc(100% - 1rem));
		}
	}

	@media (max-width: 720px) {
		.author-row {
			flex-direction: column;
			align-items: flex-start;
		}

		.author-card,
		.date-card {
			align-items: flex-start;
		}
	}
</style>
